[25.969879, "o", "\u001b[0;36m[doctest] \u001b[0mdoctest version is \"2.4.6\"\r\n\u001b[0;36m[doctest] \u001b[0mrun with \"--help\" for options\r\n\u001b[0;33m==============================================================================="]
[25.970036, "o", "\r\n\u001b[0;37m50-example-test.cpp:7:\r\n\u001b[0;33mTEST CASE:  \u001b[0mArithmetic works\r\n\r\n\u001b[0;37m50-example-test.cpp:9: \u001b[0;31mERROR: \u001b[0;36mCHECK( 2 + 3 == 6 ) \u001b[0mis NOT correct!\r\n  values: CHECK( 5 == 6 )\r\n\r\n\u001b[0;37m50-example-test.cpp:10: \u001b[0;31mERROR: \u001b[0;36mCHECK( 2 - 3 == 0 ) \u001b[0mis NOT correct!\r\n  values: CHECK( -1 == 0 )\r\n\r\n"]
[25.970116, "o", "\u001b[0m\u001b[0;33m===============================================================================\r\n\u001b[0;37m50-example-test.cpp:14:\r\n\u001b[0;33mTEST CASE:  \u001b[0mvector::emplace_back\r\n\r\n\u001b[0;37m50-example-test.cpp:22: \u001b[0;31mERROR: \u001b[0;36mCHECK( v == std::vector{1, 2, 3, 10, 20, 30} ) \u001b[0mis NOT correct!\r\n  values: CHECK( {?} == {?} )\r\n\r\n\u001b[0m\u001b[0;33m===============================================================================\r\n"]
[25.970232, "o", "\u001b[0;36m[doctest] \u001b[0mtest cases: 2 | \u001b[0m0 passed\u001b[0m | \u001b[0;31m2 failed\u001b[0m | \u001b[0m0 skipped\u001b[0m\r\n\u001b[0;36m[doctest] \u001b[0massertions: 5 | \u001b[0m2 passed\u001b[0m | \u001b[0;31m3 failed\u001b[0m |\r\n\u001b[0;36m[doctest] \u001b[0mStatus: \u001b[0;31mFAILURE!\u001b[0m\r\n"]
[25.970796, "o", "\u001b]0;yeputons@yeputons05: ~/exercises/03-210920/problem\u0007\u001b[01;32myeputons@yeputons05\u001b[00m:\u001b[01;34m~/exercises/03-210920/problem\u001b[00m$ "]
